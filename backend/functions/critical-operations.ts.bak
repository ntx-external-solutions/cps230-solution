import {
  app,
  HttpRequest,
  HttpResponseInit,
  InvocationContext,
} from '@azure/functions';
import {
  authenticateRequestUnified,
  getCorsHeaders,
  hasRole,
} from '../shared/auth';
import { query, setSessionContext, getPool } from '../shared/database';
import { validateCriticalOperationInput, ValidationError, isValidUUID } from '../shared/validation';

/**
 * Critical Operations HTTP trigger function
 * Handles CRUD operations for critical operations
 */
export async function criticalOperationsFunction(
  request: HttpRequest,
  context: InvocationContext
): Promise<HttpResponseInit> {
  const origin = request.headers.get('origin');
  const corsHeaders = getCorsHeaders(origin);

  // Handle CORS preflight
  if (request.method === 'OPTIONS') {
    return {
      status: 204,
      headers: corsHeaders,
    };
  }

  try {
    // Authenticate user
    const userProfile = await authenticateRequestUnified(request);

    // Set session context for RLS
    const pool = getPool();
    await setSessionContext(pool, userProfile.azureAdObjectId, userProfile.role, userProfile.accountId);

    const url = new URL(request.url);
    const id = url.searchParams.get('id');

    switch (request.method) {
      case 'GET':
        return await handleGet(id, userProfile, corsHeaders, context);

      case 'POST':
        return await handlePost(request, userProfile, corsHeaders, context);

      case 'PUT':
      case 'PATCH':
        return await handleUpdate(request, id, userProfile, corsHeaders, context);

      case 'DELETE':
        return await handleDelete(id, userProfile, corsHeaders, context);

      default:
        return {
          status: 405,
          headers: corsHeaders,
          jsonBody: { error: 'Method not allowed' },
        };
    }
  } catch (error: any) {
    context.error('Error in critical operations function:', error);

    const status = error instanceof ValidationError
      ? 400
      : error.message?.includes('Token')
      ? 401
      : error.message?.includes('permission') || error.message?.includes('role')
      ? 403
      : 500;

    return {
      status,
      headers: corsHeaders,
      jsonBody: {
        error: error.message || 'An error occurred',
      },
    };
  }
}

/**
 * Handle GET request - Retrieve critical operation(s)
 */
async function handleGet(
  id: string | null,
  userProfile: any,
  corsHeaders: Record<string, string>,
  context: InvocationContext
): Promise<HttpResponseInit> {
  if (id) {
    // Validate UUID
    if (!isValidUUID(id)) {
      return {
        status: 400,
        headers: corsHeaders,
        jsonBody: { error: 'Invalid critical operation ID format' },
      };
    }

    // Get single critical operation with related data
    const criticalOpResult = await query(
      `SELECT co.*,
              s.system_name,
              p.process_name
       FROM critical_operations co
       LEFT JOIN systems s ON co.system_id = s.id
       LEFT JOIN processes p ON co.process_id = p.id
       WHERE co.id = $1`,
      [id]
    );

    if (criticalOpResult.rows.length === 0) {
      return {
        status: 404,
        headers: corsHeaders,
        jsonBody: { error: 'Critical operation not found' },
      };
    }

    const criticalOp = criticalOpResult.rows[0];

    // Get associated controls
    const controlsResult = await query(
      'SELECT id, control_name, control_type FROM controls WHERE critical_operation_id = $1',
      [id]
    );

    return {
      status: 200,
      headers: corsHeaders,
      jsonBody: {
        data: {
          ...criticalOp,
          controls: controlsResult.rows,
        },
      },
    };
  } else {
    // Get all critical operations
    const criticalOpsResult = await query(
      `SELECT co.*,
              s.system_name,
              p.process_name
       FROM critical_operations co
       LEFT JOIN systems s ON co.system_id = s.id
       LEFT JOIN processes p ON co.process_id = p.id
       ORDER BY co.operation_name ASC`
    );

    return {
      status: 200,
      headers: corsHeaders,
      jsonBody: { data: criticalOpsResult.rows },
    };
  }
}

/**
 * Handle POST request - Create new critical operation
 */
async function handlePost(
  request: HttpRequest,
  userProfile: any,
  corsHeaders: Record<string, string>,
  context: InvocationContext
): Promise<HttpResponseInit> {
  // Check permissions - only promasters can modify
  if (!hasRole(userProfile.role, ['promaster'])) {
    return {
      status: 403,
      headers: corsHeaders,
      jsonBody: { error: 'Insufficient permissions. Only Promasters can create critical operations.' },
    };
  }

  const body = await request.json() as any;
  const validatedData = validateCriticalOperationInput(body);

  const result = await query(
    `INSERT INTO critical_operations (
      operation_name, description, system_id, process_id, color_code, modified_by
    ) VALUES ($1, $2, $3, $4, $5, $6)
    RETURNING *`,
    [
      validatedData.operation_name,
      validatedData.description || null,
      validatedData.system_id || null,
      validatedData.process_id || null,
      validatedData.color_code || null,
      userProfile.email,
    ]
  );

  return {
    status: 201,
    headers: corsHeaders,
    jsonBody: { data: result.rows[0] },
  };
}

/**
 * Handle PUT/PATCH request - Update critical operation
 */
async function handleUpdate(
  request: HttpRequest,
  id: string | null,
  userProfile: any,
  corsHeaders: Record<string, string>,
  context: InvocationContext
): Promise<HttpResponseInit> {
  if (!id) {
    return {
      status: 400,
      headers: corsHeaders,
      jsonBody: { error: 'Critical operation ID is required' },
    };
  }

  if (!isValidUUID(id)) {
    return {
      status: 400,
      headers: corsHeaders,
      jsonBody: { error: 'Invalid critical operation ID format' },
    };
  }

  // Check permissions - only promasters can modify
  if (!hasRole(userProfile.role, ['promaster'])) {
    return {
      status: 403,
      headers: corsHeaders,
      jsonBody: { error: 'Insufficient permissions. Only Promasters can update critical operations.' },
    };
  }

  const body = await request.json() as any;
  const validatedData = validateCriticalOperationInput(body);

  const result = await query(
    `UPDATE critical_operations SET
      operation_name = COALESCE($1, operation_name),
      description = COALESCE($2, description),
      system_id = COALESCE($3, system_id),
      process_id = COALESCE($4, process_id),
      color_code = COALESCE($5, color_code),
      modified_by = $6,
      modified_date = NOW()
    WHERE id = $7
    RETURNING *`,
    [
      validatedData.operation_name,
      validatedData.description,
      validatedData.system_id,
      validatedData.process_id,
      validatedData.color_code,
      userProfile.email,
      id,
    ]
  );

  if (result.rows.length === 0) {
    return {
      status: 404,
      headers: corsHeaders,
      jsonBody: { error: 'Critical operation not found' },
    };
  }

  return {
    status: 200,
    headers: corsHeaders,
    jsonBody: { data: result.rows[0] },
  };
}

/**
 * Handle DELETE request - Delete critical operation
 */
async function handleDelete(
  id: string | null,
  userProfile: any,
  corsHeaders: Record<string, string>,
  context: InvocationContext
): Promise<HttpResponseInit> {
  if (!id) {
    return {
      status: 400,
      headers: corsHeaders,
      jsonBody: { error: 'Critical operation ID is required' },
    };
  }

  if (!isValidUUID(id)) {
    return {
      status: 400,
      headers: corsHeaders,
      jsonBody: { error: 'Invalid critical operation ID format' },
    };
  }

  // Check permissions - only promasters can modify
  if (!hasRole(userProfile.role, ['promaster'])) {
    return {
      status: 403,
      headers: corsHeaders,
      jsonBody: { error: 'Insufficient permissions. Only Promasters can delete critical operations.' },
    };
  }

  const result = await query('DELETE FROM critical_operations WHERE id = $1 RETURNING id', [id]);

  if (result.rows.length === 0) {
    return {
      status: 404,
      headers: corsHeaders,
      jsonBody: { error: 'Critical operation not found' },
    };
  }

  return {
    status: 200,
    headers: corsHeaders,
    jsonBody: { success: true },
  };
}

// Register the function
app.http('critical-operations', {
  methods: ['GET', 'POST', 'PUT', 'PATCH', 'DELETE', 'OPTIONS'],
  authLevel: 'anonymous',
  handler: criticalOperationsFunction,
});
