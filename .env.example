# =================================================================
# CPS230 Solution - Environment Variables Template
# =================================================================
# IMPORTANT: Copy this file to .env and fill in your actual values
# NEVER commit .env files to git - they contain sensitive credentials
# =================================================================

# -----------------------------------------------------------------
# FRONTEND CONFIGURATION (Static Web App)
# -----------------------------------------------------------------
# Used by React/Vite frontend application

# API endpoint for backend Azure Functions
# Development: http://localhost:7071/api
# Production: https://func-cps230-{env}-{unique}.azurewebsites.net/api
VITE_API_URL=https://your-function-app.azurewebsites.net/api

# Azure AD SSO Configuration (for organizational users)
# Get these from your Azure AD App Registration
VITE_AZURE_TENANT_ID=your-azure-tenant-id
VITE_AZURE_CLIENT_ID=your-azure-client-id

# Redirect URI for Azure AD authentication
# Development: http://localhost:5173
# Production: https://your-static-web-app.azurestaticapps.net
VITE_REDIRECT_URI=http://localhost:5173

# -----------------------------------------------------------------
# BACKEND CONFIGURATION (Azure Functions)
# -----------------------------------------------------------------
# These are configured in Azure Portal Function App Settings

# PostgreSQL Database Connection
# Format: postgresql://username:password@host:port/database?sslmode=require
POSTGRESQL_CONNECTION_STRING=postgresql://cps230admin:your-password@your-server.postgres.database.azure.com:5432/cps230?sslmode=require

# Alternative PostgreSQL connection format (if using .NET style)
# POSTGRESQL_CONNECTION_STRING=Host=your-server.postgres.database.azure.com;Database=cps230;Username=cps230admin;Password=your-password;SSL Mode=Require

# Azure Key Vault (for secrets management)
KEY_VAULT_URI=https://your-keyvault.vault.azure.net/

# Azure AD SSO Configuration (for validating SSO tokens on backend)
AZURE_TENANT_ID=your-azure-tenant-id
AZURE_CLIENT_ID=your-azure-client-id

# CRITICAL: JWT Secret for Local User Authentication
# MUST be at least 32 characters long
# Generate with: openssl rand -base64 48
# NEVER use a weak or default value in production!
JWT_SECRET=REPLACE_WITH_SECURE_RANDOM_STRING_AT_LEAST_32_CHARACTERS_LONG

# CORS Configuration
# Comma-separated list of allowed origins (no spaces)
ALLOWED_ORIGINS=https://your-static-web-app.azurestaticapps.net,http://localhost:5173
STATIC_WEB_APP_URL=https://your-static-web-app.azurestaticapps.net

# Environment
# Options: development, production
NODE_ENV=production

# -----------------------------------------------------------------
# DATABASE INITIALIZATION (for init scripts)
# -----------------------------------------------------------------
# Used by database/init-database.sh script

POSTGRES_HOST=your-server.postgres.database.azure.com
POSTGRES_DB=cps230
POSTGRES_USER=cps230admin
POSTGRES_PASSWORD=your-secure-password

# -----------------------------------------------------------------
# MONITORING (auto-configured by Azure)
# -----------------------------------------------------------------

# Application Insights connection string
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=your-key;IngestionEndpoint=https://...

# -----------------------------------------------------------------
# DEVELOPMENT ONLY
# -----------------------------------------------------------------
# Uncomment these for local development

# NODE_ENV=development
# VITE_API_URL=http://localhost:7071/api
# VITE_REDIRECT_URI=http://localhost:5173

# -----------------------------------------------------------------
# SECURITY NOTES
# -----------------------------------------------------------------
# 1. JWT_SECRET must be at least 32 characters (deployment will fail otherwise)
# 2. PostgreSQL passwords should be complex (min 8 chars, mix of upper/lower/numbers/symbols)
# 3. Never commit .env files to git (.gitignore should block them)
# 4. Use Azure Key Vault references in production for sensitive values
# 5. Rotate JWT_SECRET and database passwords regularly
# -----------------------------------------------------------------
